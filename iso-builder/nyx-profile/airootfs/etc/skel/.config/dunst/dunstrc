# NYXUS dunst configuration
# Matches the system-wide graffiti chrome: black frosted backgrounds,
# neon-pink frame, hand-written font. Drop into ~/.config/dunst/dunstrc
# and run: pkill -USR1 dunst (or systemctl --user restart dunst).

[global]
    monitor = 0
    follow = mouse

    width = (200, 460)
    height = 220
    origin = top-right
    offset = 18x80
    scale = 0
    notification_limit = 6

    progress_bar = true
    progress_bar_height = 12
    progress_bar_frame_width = 2
    progress_bar_min_width = 200
    progress_bar_max_width = 420
    progress_bar_corner_radius = 4

    indicate_hidden = yes
    transparency = 12
    separator_height = 3
    padding = 14
    horizontal_padding = 16
    text_icon_padding = 10
    frame_width = 3
    frame_color = "#e8edf5"
    gap_size = 6
    separator_color = frame
    sort = yes

    font = Caveat 14
    line_height = 2
    markup = full
    format = "<b>%a · %s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    icon_position = left
    min_icon_size = 32
    max_icon_size = 96
    icon_corner_radius = 4
    icon_path = /usr/share/icons/Adwaita/32x32/status/:/usr/share/icons/Adwaita/32x32/devices/:/usr/share/icons/hicolor/32x32/apps/

    sticky_history = yes
    history_length = 50

    dmenu = /usr/bin/rofi -dmenu -p dunst:
    browser = /usr/bin/xdg-open
    always_run_script = true
    title = NYXUS Notifications
    class = Dunst
    corner_radius = 6
    ignore_dbusclose = false

    force_xwayland = false
    force_xinerama = false
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[experimental]
    per_monitor_dpi = false

[urgency_low]
    background = "#0a0a12"
    foreground = "#c8ccd6"
    frame_color = "#c8ccd6"
    timeout = 6
    default_icon = dialog-information

[urgency_normal]
    background = "#0a0a12"
    foreground = "#ffffff"
    frame_color = "#e8edf5"
    timeout = 8
    override_pause_level = 30
    default_icon = dialog-information

[urgency_critical]
    background = "#0a0a12"
    foreground = "#e8edf5"
    frame_color = "#ff3030"
    timeout = 0
    override_pause_level = 60
    default_icon = dialog-warning

# Per-app overrides — match NYXUS app classes
[nyxus_terminal]
    appname = nyxus-terminal
    foreground = "#c8ccd6"
    frame_color = "#c8ccd6"

[nyxus_settings]
    appname = nyxus-settings
    foreground = "#e8edf5"
    frame_color = "#e8edf5"

[nyxus_control]
    appname = nyxus-control
    foreground = "#c8ccd6"
    frame_color = "#c8ccd6"
