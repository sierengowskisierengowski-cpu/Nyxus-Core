(defwindow bar-bottom
  :monitor 0 :stacking "fg" :exclusive true :namespace "nyxus-bar-bottom"
  :geometry (geometry :x "0" :y "12" :width "98%" :height "56px" :anchor "bottom center")
  (bar_bottom_layout))

(defwindow bar-top
  :monitor 0 :stacking "fg" :exclusive true :namespace "nyxus-bar-top"
  :geometry (geometry :x "0" :y "0" :width "100%" :height "32px" :anchor "top center")
  (bar_top_layout))

(defwindow bar-left
  :monitor 0 :stacking "fg" :exclusive true :namespace "nyxus-bar-left"
  :geometry (geometry :x "10" :y "0" :width "56px" :height "70%" :anchor "center left")
  (workspaces_rail))

(defwindow bar-right
  :monitor 0 :stacking "fg" :exclusive true :namespace "nyxus-bar-right"
  :geometry (geometry :x "10" :y "0" :width "56px" :height "70%" :anchor "center right")
  (app_rail))

(defwindow dashboard
