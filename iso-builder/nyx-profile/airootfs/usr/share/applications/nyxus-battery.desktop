[Desktop Entry]
Type=Application
Name=NYXUS Battery Health
GenericName=Battery Health
Comment=Battery wear, cycles, capacity
Exec=/usr/local/bin/nyxus battery
TryExec=/usr/local/bin/nyxus
Icon=battery
Terminal=false
Categories=System;Monitor;
Keywords=NYXUS;Battery;Health;Power;
StartupNotify=true
