[Desktop Entry]
Type=Application
Name=NYXUS Spotlight
GenericName=Spotlight
Comment=Quick launcher and file search
Exec=/usr/local/bin/nyxus launcher
TryExec=/usr/local/bin/nyxus
Icon=system-search
Terminal=false
Categories=Utility;
Keywords=NYXUS;NYX;Spotlight;
StartupNotify=true
StartupWMClass=nyxus.launcher
X-NYXUS-Module=nyxus_launcher
