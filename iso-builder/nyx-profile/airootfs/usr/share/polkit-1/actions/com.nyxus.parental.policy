<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE policyconfig PUBLIC
 "-//freedesktop//DTD PolicyKit Policy Configuration 1.0//EN"
 "http://www.freedesktop.org/standards/PolicyKit/1.0/policyconfig.dtd">
<!-- NYXUS Parental Controls polkit policy   rev 2026-05-13 r1 -->
<policyconfig>
  <vendor>NYXUS</vendor>
  <vendor_url>https://nyxus.os</vendor_url>
  <icon_name>preferences-system-parental-controls</icon_name>
  <action id="com.nyxus.parental.helper">
    <description>NYXUS Parental Controls privileged action</description>
    <message>NYXUS Parental Controls needs administrator access to update the device-wide parental policy.</message>
    <defaults>
      <allow_any>auth_admin</allow_any>
      <allow_inactive>auth_admin</allow_inactive>
      <allow_active>auth_admin_keep</allow_active>
    </defaults>
    <annotate key="org.freedesktop.policykit.exec.path">/usr/local/libexec/nyxus-parental-helper</annotate>
    <annotate key="org.freedesktop.policykit.exec.allow_gui">true</annotate>
  </action>
</policyconfig>
