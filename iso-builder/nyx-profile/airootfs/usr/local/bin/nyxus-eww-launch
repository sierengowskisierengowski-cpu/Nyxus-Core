#!/usr/bin/env bash
# ╔══════════════════════════════════════════════════════════════════════╗
# ║  NYXUS — EWW launcher                                                ║
# ║  Lives at: /usr/local/bin/nyxus-eww-launch                           ║
# ║                                                                      ║
# ║  Waits for the eww IPC socket to appear (daemon up), then opens      ║
# ║  the four bars. Closing first guards against duplicate windows on    ║
# ║  Hyprland config-reload.                                             ║
# ║                                                                      ║
# ║  © 2026 JOSEPH SIERENGOWSKI · NYX-J5W-2026-SIERENGOWSKI-LOCKED       ║
# ╚══════════════════════════════════════════════════════════════════════╝
set -u

SOCK="${XDG_RUNTIME_DIR:-/tmp}/eww-server_default"
TIMEOUT=30
elapsed=0
while [[ ! -S "$SOCK" && $elapsed -lt $TIMEOUT ]]; do
  sleep 0.3
  elapsed=$((elapsed + 1))
done

if [[ ! -S "$SOCK" ]]; then
  notify-send -u critical "NYXUS EWW" "Daemon socket never appeared — bars not started." 2>/dev/null || true
  exit 1
fi

# Close any pre-existing windows from a prior session, then open fresh.
eww close-all 2>/dev/null || true
sleep 0.2

eww open bar-bottom
eww open bar-top
eww open bar-left
eww open bar-right
