#!/usr/bin/env bash
# nyxus-welcome — launcher for the NYXUS onboarding wizard.
#
# Usage:
#   nyxus-welcome              Launch (skips if ~/.config/nyxus/welcome.done exists)
#   nyxus-welcome --force      Launch even if already completed
#   nyxus-welcome --mark-done  Just mark complete (used by --skip flow)
#   nyxus-welcome --reset      Wipe welcome.done and re-arm autostart
#
# The wizard itself lives at /opt/nyxus/nyxus_welcome.py.
set -euo pipefail

WIZARD="/opt/nyxus/nyxus_welcome.py"
DONE="${HOME}/.config/nyxus/welcome.done"
AUTOSTART="${HOME}/.config/autostart/nyxus-welcome.desktop"

if [[ ! -f "${WIZARD}" ]]; then
  echo "nyxus-welcome: wizard missing at ${WIZARD}" >&2
  exit 1
fi

case "${1:-}" in
  --reset)
    rm -f "${DONE}"
    mkdir -p "$(dirname "${AUTOSTART}")"
    cat > "${AUTOSTART}" <<EOF
[Desktop Entry]
Type=Application
Name=NYXUS Welcome
Exec=nyxus-welcome
X-GNOME-Autostart-enabled=true
NoDisplay=true
EOF
    echo "welcome reset — will re-run on next login"
    exit 0
    ;;
  --mark-done)
    exec python3 "${WIZARD}" --mark-done
    ;;
  --force)
    exec python3 "${WIZARD}" --force
    ;;
  ""|--help|-h)
    if [[ "${1:-}" =~ ^(-h|--help)$ ]]; then
      sed -n '2,/^set -euo/p' "$0" | sed 's/^# \{0,1\}//;/^set -euo/d'
      exit 0
    fi
    exec python3 "${WIZARD}"
    ;;
  *)
    echo "nyxus-welcome: unknown flag: $1" >&2
    echo "try: nyxus-welcome --help" >&2
    exit 2
    ;;
esac
