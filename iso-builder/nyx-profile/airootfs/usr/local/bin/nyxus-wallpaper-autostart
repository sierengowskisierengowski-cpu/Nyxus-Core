#!/usr/bin/env bash
# nyxus-wallpaper-autostart
#
# Read the user's persisted wallpaper choice and exec swaybg. Falls back
# to the shipped default if the config is missing or points at a file
# that no longer exists. Sourced by hyprland.conf exec-once and the
# bound $mod+ALT+W key.
set -u

CONF="${HOME}/.config/nyxus/wallpaper.conf"
DEFAULT="/usr/share/backgrounds/nyxus/nyxus-void-vortex.svg"
LEGACY_PNG="${HOME}/.config/hypr/walls/nyxus-void-vortex.png"

WALLPAPER_PATH=""
if [[ -r "${CONF}" ]]; then
  # shellcheck source=/dev/null
  source "${CONF}" || true
fi

if [[ -z "${WALLPAPER_PATH:-}" || ! -r "${WALLPAPER_PATH}" ]]; then
  if [[ -r "${DEFAULT}" ]]; then
    WALLPAPER_PATH="${DEFAULT}"
  elif [[ -r "${LEGACY_PNG}" ]]; then
    WALLPAPER_PATH="${LEGACY_PNG}"
  else
    echo "nyxus-wallpaper-autostart: no readable wallpaper found" >&2
    exit 1
  fi
fi

pkill -x swaybg 2>/dev/null || true
exec swaybg -i "${WALLPAPER_PATH}" -m fill -c "#000000"
