#!/usr/bin/env bash
# nyxus-apply-accent [preset-name]
#
# Read ~/.config/nyxus/accent.json (or the skel copy), pick the active
# preset (or the one passed on the CLI), and:
#   1. Write ~/.config/eww/accent.scss with $nyxus-accent-* SCSS vars
#   2. Touch the eww theme file so eww picks it up via reload
#   3. Update ~/.config/gtk-3.0/gtk.css and ~/.config/gtk-4.0/gtk.css
#      with @define-color overrides for the accent
#   4. Persist the chosen preset back into accent.json
set -u

CONF="${HOME}/.config/nyxus/accent.json"
[[ -r "${CONF}" ]] || CONF="/etc/skel/.config/nyxus/accent.json"

if ! command -v jq >/dev/null 2>&1; then
  echo "jq is required to apply accent" >&2
  exit 1
fi

NAME="${1:-$(jq -r '.active // "aurora"' "${CONF}")}"

PRIMARY=$(jq -r --arg n "${NAME}" '.presets[$n].primary   // empty' "${CONF}")
SECOND=$(jq -r  --arg n "${NAME}" '.presets[$n].secondary // empty' "${CONF}")
WARN=$(jq -r    --arg n "${NAME}" '.presets[$n].warn      // empty' "${CONF}")
OK=$(jq -r      --arg n "${NAME}" '.presets[$n].ok        // empty' "${CONF}")

if [[ -z "${PRIMARY}" ]]; then
  echo "no preset named '${NAME}' in ${CONF}" >&2
  exit 1
fi

mkdir -p "${HOME}/.config/eww" "${HOME}/.config/gtk-3.0" "${HOME}/.config/gtk-4.0" "${HOME}/.config/nyxus"

EWW_OUT="${HOME}/.config/eww/accent.scss"
cat > "${EWW_OUT}" <<EOF
// generated by nyxus-apply-accent — do not hand-edit
\$nyxus-accent-primary:   ${PRIMARY};
\$nyxus-accent-secondary: ${SECOND};
\$nyxus-accent-warn:      ${WARN};
\$nyxus-accent-ok:        ${OK};
EOF

for V in 3.0 4.0; do
  GTK="${HOME}/.config/gtk-${V}/gtk.css"
  # Strip any prior @define-color block we wrote, then append new ones.
  if [[ -f "${GTK}" ]]; then
    sed -i '/\/\* nyxus-accent-begin \*\//,/\/\* nyxus-accent-end \*\//d' "${GTK}"
  fi
  cat >> "${GTK}" <<EOF

/* nyxus-accent-begin */
@define-color accent_color ${PRIMARY};
@define-color accent_bg_color ${PRIMARY};
@define-color accent_fg_color #0a0d14;
/* nyxus-accent-end */
EOF
done

# Persist active preset
TMP="$(mktemp)"
jq --arg n "${NAME}" '.active = $n' "${CONF}" > "${TMP}" && mv "${TMP}" "${HOME}/.config/nyxus/accent.json"

# Bump eww so it reloads
if command -v eww >/dev/null 2>&1; then
  eww reload 2>/dev/null || true
fi

echo "accent: applied '${NAME}' (primary=${PRIMARY}, secondary=${SECOND})"
