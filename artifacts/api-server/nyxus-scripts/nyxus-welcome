#!/usr/bin/env bash
# NYXUS · Welcome Wizard launcher  rev 2026.05.11-r9-eww
#
# Gating logic (so this only ever runs once unless forced):
#   • Skips silently if ~/.nyxus/welcome-done exists.
#   • Skips if NYXUS_NO_WELCOME=1.
#   • Re-runs if NYXUS_WELCOME_FORCE=1.
#
# Hyprland exec-once line installs this so it fires on first interactive
# login.  Wait briefly for the bar / wallpaper to settle so the wizard
# doesn't paint over an in-progress compositor scene.
set -u

MARKER="$HOME/.nyxus/welcome-done"
LOCK="/tmp/nyxus-welcome.lock"

[[ -f "$MARKER" && -z "${NYXUS_WELCOME_FORCE:-}" ]] && exit 0
[[ -n "${NYXUS_NO_WELCOME:-}" ]] && exit 0

# single-instance lock
exec 9>"$LOCK"
flock -n 9 || exit 0

# settle delay so swaybg + eww are up
sleep 2

# Locate the python module (installed by customize_airootfs into ~/.nyxus)
PY="$HOME/.nyxus/nyxus_welcome.py"
[[ -x "$PY" ]] || PY="$HOME/.nyxus/nyxus_welcome.py"
[[ -f "$PY" ]] || { echo "nyxus-welcome: script missing at $PY" >&2; exit 1; }

exec python3 "$PY" "$@"
