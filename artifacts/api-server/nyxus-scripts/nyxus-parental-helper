#!/usr/bin/env bash
# NYXUS · Parental Controls helper.
#
# Privileged helper invoked via pkexec. ALL actions are reversible; this
# helper writes only to /etc/hosts.d/nyxus-parental and a systemd timer
# under /etc/systemd/system/nyxus-parental-*.timer. The user-level
# Settings page is the only writer.
#
# Subcommands:
#   add-host-block <hostname>            # append to blocklist
#   remove-host-block <hostname>         # remove from blocklist
#   list-host-blocks                     # print blocklist
#   set-bedtime <user> <HH:MM> <HH:MM>   # auto-lock from start..end
#   clear-bedtime <user>                 # disable scheduled lock
#   list-bedtimes                        # show all bedtime timers
#
# Project-preference compliance: NO account lockouts, NO faillock, NO
# password lockouts. Bedtime works by sending `loginctl lock-session`
# at the start window — the user can unlock at any time with their
# password. This is a NUDGE, not a hard lockout.
set -euo pipefail
IFS=$'\n\t'
umask 022

LOG=/var/log/nyxus-parental.log
HOST_DIR=/etc/hosts.d
HOST_BLOCKLIST="${HOST_DIR}/nyxus-parental"
HOSTS=/etc/hosts
USER_RE='^[a-z_][a-z0-9_-]{0,31}$'
HOST_RE='^[A-Za-z0-9]([A-Za-z0-9.-]{0,253}[A-Za-z0-9])?$'
TIME_RE='^([01][0-9]|2[0-3]):[0-5][0-9]$'

logmsg() { printf '%s [parental] %s\n' "$(date -Iseconds)" "$*" >> "$LOG" 2>/dev/null || true; }

usage() {
  cat <<'EOF' >&2
nyxus-parental-helper — NYXUS Parental Controls privileged helper

  add-host-block <hostname>
  remove-host-block <hostname>
  list-host-blocks
  set-bedtime <user> <start HH:MM> <end HH:MM>
  clear-bedtime <user>
  list-bedtimes
EOF
  exit 2
}

ensure_blocklist() {
  mkdir -p "$HOST_DIR"
  [[ -f "$HOST_BLOCKLIST" ]] || {
    printf "# NYXUS Parental Controls — managed file, do not edit by hand\n" \
      > "$HOST_BLOCKLIST"
  }
  # World-readable so the Settings UI can display the list without a
  # gratuitous pkexec prompt. Mutating actions still require root via
  # pkexec → this script.
  chmod 0644 "$HOST_BLOCKLIST"
  if ! grep -q "# nyxus-parental:start" "$HOSTS"; then
    {
      printf "\n# nyxus-parental:start (managed by nyxus-parental-helper)\n"
      cat "$HOST_BLOCKLIST"
      printf "# nyxus-parental:end\n"
    } >> "$HOSTS"
  fi
}

resync_hosts() {
  # Replace the block between the start/end markers with the current
  # blocklist contents. Idempotent.
  python3 - <<PY
import re, pathlib
HOSTS = pathlib.Path("$HOSTS")
BL    = pathlib.Path("$HOST_BLOCKLIST")
src   = HOSTS.read_text()
body  = BL.read_text() if BL.exists() else ""
block = ("\n# nyxus-parental:start (managed by nyxus-parental-helper)\n"
         + body
         + "# nyxus-parental:end\n")
pat = re.compile(r"\n# nyxus-parental:start.*?# nyxus-parental:end\n",
                 re.DOTALL)
new = pat.sub(block, src) if pat.search(src) else src + block
HOSTS.write_text(new)
PY
}

cmd="${1:-}"; shift || true
case "$cmd" in
  add-host-block)
    h="${1:-}"
    [[ "$h" =~ $HOST_RE ]] || { echo "bad hostname" >&2; exit 2; }
    ensure_blocklist
    # Fixed-string match — `grep -F` treats dots as literal, so
    # foo.example.com cannot accidentally match foo-example-com.
    if grep -Fxq "0.0.0.0 ${h}" "$HOST_BLOCKLIST"; then
      echo "already blocked" >&2; exit 0
    fi
    printf "0.0.0.0 %s\n" "$h" >> "$HOST_BLOCKLIST"
    resync_hosts
    logmsg "blocked $h"
    ;;

  remove-host-block)
    h="${1:-}"
    [[ "$h" =~ $HOST_RE ]] || { echo "bad hostname" >&2; exit 2; }
    [[ -f "$HOST_BLOCKLIST" ]] || exit 0
    # Fixed-string filter via grep -vFx — same anti-regex safety as
    # add-host-block above. Atomic write to a temp file first.
    tmp="$(mktemp "${HOST_BLOCKLIST}.XXXXXX")"
    grep -vFx "0.0.0.0 ${h}" "$HOST_BLOCKLIST" > "$tmp" || true
    chmod 0644 "$tmp"
    mv "$tmp" "$HOST_BLOCKLIST"
    resync_hosts
    logmsg "unblocked $h"
    ;;

  list-host-blocks)
    [[ -f "$HOST_BLOCKLIST" ]] && cat "$HOST_BLOCKLIST" || true
    ;;

  set-bedtime)
    u="${1:-}"; s="${2:-}"; e="${3:-}"
    [[ "$u" =~ $USER_RE ]] || { echo "bad user" >&2; exit 2; }
    [[ "$s" =~ $TIME_RE ]] || { echo "bad start time" >&2; exit 2; }
    [[ "$e" =~ $TIME_RE ]] || { echo "bad end time"   >&2; exit 2; }
    svc="/etc/systemd/system/nyxus-parental-bedtime-${u}.service"
    tim="/etc/systemd/system/nyxus-parental-bedtime-${u}.timer"
    # The bedtime "window" is [start, end]. We re-lock every 10 minutes
    # *while inside that window* so a child who unlocks mid-bedtime
    # gets nudged again shortly after — that's the actual end-time
    # use. The Service script computes whether HH:MM is in the window
    # (handles overnight wrap when end < start). Lock is loginctl only;
    # never PAM, never faillock.
    cat > "$svc" <<UNIT
[Unit]
Description=NYXUS Parental bedtime nudge for ${u} (window ${s}–${e})

[Service]
Type=oneshot
Environment=BED_USER=${u}
Environment=BED_START=${s}
Environment=BED_END=${e}
ExecStart=/bin/sh -c '\
  now=\$(date +%H:%M); \
  in_win() { \
    s="\$BED_START"; e="\$BED_END"; n="\$1"; \
    if [ "\$s" \\< "\$e" ] || [ "\$s" = "\$e" ]; then \
      [ "\$n" \\>= "\$s" ] && [ "\$n" \\< "\$e" ]; \
    else \
      [ "\$n" \\>= "\$s" ] || [ "\$n" \\< "\$e" ]; \
    fi; \
  }; \
  if in_win "\$now"; then \
    su - "\$BED_USER" -c "notify-send -u critical \\"Bedtime\\" \\"NYXUS Parental: window \$BED_START-\$BED_END active\\" || true"; \
    loginctl lock-sessions || true; \
  fi'
UNIT
    cat > "$tim" <<UNIT
[Unit]
Description=NYXUS Parental bedtime timer for ${u} (re-checks every 10 min)

[Timer]
# Wake every 10 minutes; the service decides whether we're inside the
# window and locks if so. This means END time genuinely matters: as
# soon as the wall clock leaves the window, no further locks fire.
OnCalendar=*:0/10
Persistent=false

[Install]
WantedBy=timers.target
UNIT
    systemctl daemon-reload
    systemctl enable --now "nyxus-parental-bedtime-${u}.timer"
    logmsg "bedtime ${u} ${s}-${e} enabled"
    ;;

  clear-bedtime)
    u="${1:-}"
    [[ "$u" =~ $USER_RE ]] || { echo "bad user" >&2; exit 2; }
    systemctl disable --now "nyxus-parental-bedtime-${u}.timer" 2>/dev/null || true
    rm -f "/etc/systemd/system/nyxus-parental-bedtime-${u}.service" \
          "/etc/systemd/system/nyxus-parental-bedtime-${u}.timer"
    systemctl daemon-reload
    logmsg "bedtime ${u} cleared"
    ;;

  list-bedtimes)
    systemctl list-timers --all 2>/dev/null \
      | grep -E "nyxus-parental-bedtime-" || true
    ;;

  *) usage ;;
esac
