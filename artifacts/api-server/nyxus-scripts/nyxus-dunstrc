# NYXUS dunst configuration · Sprint E Total Identity

[global]
    monitor = 0
    follow = mouse

    width = (320, 460)
    height = (60, 220)
    origin = top-right
    offset = 18x80
    scale = 0
    notification_limit = 6

    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 240
    progress_bar_max_width = 420
    progress_bar_corner_radius = 3

    indicate_hidden = yes
    transparency = 4
    separator_height = 1
    padding = 14
    horizontal_padding = 16
    text_icon_padding = 12
    frame_width = 1
    frame_color = "#7B5EA766"
    gap_size = 6
    separator_color = "#080808"
    sort = yes

    font = JetBrains Mono Nerd Font 11
    line_height = 3
    markup = full
    format = "<b>%a · %s</b>\n%b"
    alignment = left
    vertical_alignment = top
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    icon_position = left
    min_icon_size = 32
    max_icon_size = 64
    icon_corner_radius = 3
    icon_path = /usr/share/icons/Adwaita/32x32/status/:/usr/share/icons/Adwaita/32x32/devices/:/usr/share/icons/hicolor/32x32/apps/

    sticky_history = yes
    history_length = 50

    dmenu = /usr/bin/rofi -dmenu -p dunst:
    browser = /usr/bin/xdg-open
    always_run_script = true
    title = NYXUS Notifications
    class = Dunst
    corner_radius = 3
    ignore_dbusclose = false

    force_xwayland = false
    force_xinerama = false
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[experimental]
    per_monitor_dpi = false

[urgency_low]
    background    = "#080808f7"
    foreground    = "#C8C0C0cc"
    frame_color   = "#7B5EA766"
    timeout       = 5
    default_icon  = dialog-information

[urgency_normal]
    background    = "#080808f7"
    foreground    = "#C8C0C0"
    frame_color   = "#7B5EA766"
    timeout       = 8
    override_pause_level = 30
    default_icon  = dialog-information

[urgency_critical]
    background    = "#080808f7"
    foreground    = "#C8C0C0"
    frame_color   = "#8B4040"
    timeout       = 0
    override_pause_level = 60
    default_icon  = dialog-warning
