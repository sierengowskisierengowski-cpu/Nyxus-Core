[
  {
    "name": "top",
    "layer": "top",
    "position": "top",
    "height": 28,
    "spacing": 0,
    "margin-top": 0,
    "margin-left": 0,
    "margin-right": 0,
    "modules-left": [
      "custom/ticker"
    ],
    "modules-center": [
      "custom/nyxus"
    ],
    "modules-right": [],
    "custom/ticker": {
      "exec": "~/.config/waybar/ticker.sh",
      "interval": 1,
      "format": "{}",
      "tooltip": false
    },
    "custom/nyxus": {
      "format": "<span foreground='#ff00ff' font_weight='bold'>N</span><span foreground='#ff5500' font_weight='bold'> Y</span><span foreground='#ffff00' font_weight='bold'> X</span><span foreground='#39ff14' font_weight='bold'> U</span><span foreground='#0088ff' font_weight='bold'> S</span>",
      "tooltip": false,
      "escape": false
    },
    "custom/sep": {
      "format": "◈",
      "tooltip": false
    },
    "cpu": {
      "format": "  {usage}%",
      "interval": 2,
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#cc00ff'>NYXUS · CPU</span>\n<span size='small' foreground='#b8a8d0'>Processor utilization</span>"
    },
    "memory": {
      "format": "  {percentage}%",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#8800ff'>NYXUS · Memory</span>\n<span size='small' foreground='#b8a8d0'>RAM usage</span>"
    },
    "temperature": {
      "hwmon-path-abs": "/sys/class/thermal/thermal_zone0/temp",
      "input-filename": "temp",
      "critical-threshold": 80,
      "format": "  {temperatureC}°C",
      "format-critical": "  {temperatureC}°C",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#39ff14'>NYXUS · Temp</span>\n<span size='small' foreground='#b8a8d0'>Thermal sensor</span>"
    },
    "network": {
      "format-wifi": "  {essid}  ↓{bandwidthDownBytes}  ↑{bandwidthUpBytes}",
      "format-ethernet": "  ETH  ↓{bandwidthDownBytes}  ↑{bandwidthUpBytes}",
      "format-disconnected": "  NO NET",
      "interval": 2,
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#ffd700'>NYXUS · Network</span>\n<span size='small' foreground='#b8a8d0'>{ipaddr} · {ifname}</span>"
    },
    "battery": {
      "format": "{icon}  {capacity}%",
      "format-charging": "  {capacity}%",
      "format-plugged": "  {capacity}%",
      "format-icons": [
        "",
        "",
        "",
        "",
        ""
      ],
      "states": {
        "warning": 30,
        "critical": 15
      },
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#ffd700'>NYXUS · Battery</span>\n<span size='small' foreground='#b8a8d0'>{capacity}% · {time}</span>"
    },
    "clock": {
      "interval": 1,
      "format": "  {:%H:%M:%S}",
      "format-alt": "  {:%a %b %d  ·  %H:%M:%S}",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#ff00ff'>NYXUS · Time</span>\n<span size='small' foreground='#b8a8d0'><span foreground='#ffffff'>{:%A · %B %d, %Y}</span></span>"
    }
  },
  {
    "name": "bottom",
    "layer": "top",
    "position": "bottom",
    "height": 60,
    "spacing": 0,
    "margin-bottom": 0,
    "margin-left": 0,
    "margin-right": 0,
    "modules-left": [
      "custom/nyxus-start"
    ],
    "modules-center": [
      "hyprland/workspaces"
    ],
    "modules-right": [
      "custom/quicksettings",
      "clock#bottom",
      "custom/nyxus-panel"
    ],
    "custom/start": {
      "format": "✕",
      "escape": false,
      "tooltip": true,
      "on-click": "/home/nyx/.local/bin/nyxus-start",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#ff00ff'>NYXUS · Start</span>\n<span size='small' foreground='#b8a8d0'>Application launcher</span>"
    },
    "custom/quicksettings": {
      "format": "",
      "tooltip": true,
      "on-click": "python3 ~/.config/waybar/quicksettings.py",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#a78bfa'>NYXUS · QuickSettings</span>\n<span size='small' foreground='#b8a8d0'>Toggles · Volume · Brightness</span>"
    },
    "hyprland/workspaces": {
      "format": "{id}",
      "on-click": "activate",
      "sort-by-number": true,
      "active-only": false,
      "persistent-workspaces": {
        "*": 6
      }
    },
    "hyprland/window": {
      "format": "{}",
      "max-length": 52,
      "separate-outputs": true
    },
    "clock#bottom": {
      "interval": 1,
      "format": "  {:%a · %d %b %Y · %H:%M:%S}",
      "format-alt": "  {:%H:%M:%S}",
      "tooltip-format": "<span font='JetBrains Mono 13' foreground='#ff00ff'><b> {:%A}</b></span>\n<span font='JetBrains Mono 11' foreground='#ffffff'> {:%d %B %Y}</span>\n\n<span font='JetBrains Mono 10'><tt>{calendar}</tt></span>",
      "calendar": {
        "mode": "month",
        "on-scroll": 1,
        "format": {
          "months": "<span foreground='#ff00ff' font_weight='bold'>{}</span>",
          "days": "<span foreground='#ffffff'>{}</span>",
          "weeks": "<span foreground='#0088ff'><b>W{}</b></span>",
          "weekdays": "<span foreground='#ffff00' font_weight='bold'>{}</span>",
          "today": "<span foreground='#39ff14' font_weight='bold'><u>{}</u></span>"
        }
      }
    },
    "bluetooth": {
      "format": "  ",
      "format-disabled": "",
      "format-connected": "  {num_connections}",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#0088ff'>NYXUS · Bluetooth</span>\n<span size='small' foreground='#b8a8d0'>{controller_alias}\n{device_enumerate}</span>",
      "on-click": "blueman-manager"
    },
    "network#bottom": {
      "format-wifi": "  {signalStrength}%",
      "format-ethernet": "  ETH",
      "format-disconnected": "  ",
      "tooltip-format-wifi": "<span size='x-large' weight='bold' foreground='#ffd700'>NYXUS · Wi-Fi</span>\n<span size='small' foreground='#b8a8d0'>{essid}  ·  {signalStrength}%\n{ipaddr}</span>",
      "on-click": "nm-connection-editor",
      "tooltip-format-ethernet": "<span size='x-large' weight='bold' foreground='#ffd700'>NYXUS · Ethernet</span>\n<span size='small' foreground='#b8a8d0'>{ifname}  ·  {ipaddr}</span>",
      "tooltip-format-disconnected": "<span size='x-large' weight='bold' foreground='#ffd700'>NYXUS · Network</span>\n<span size='small' foreground='#b8a8d0'>No connection</span>"
    },
    "pulseaudio": {
      "format": "  {volume}%",
      "format-muted": "  ",
      "scroll-step": 5,
      "on-click": "pavucontrol",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#ff00ff'>NYXUS · Audio</span>\n<span size='small' foreground='#b8a8d0'>{volume}%  ·  {desc}</span>"
    },
    "battery#bottom": {
      "format": "{icon}  {capacity}%",
      "format-charging": "  {capacity}%",
      "format-plugged": "  {capacity}%",
      "format-icons": [
        "",
        "",
        "",
        "",
        ""
      ],
      "states": {
        "warning": 30,
        "critical": 15
      }
    },
    "tray": {
      "icon-size": 14,
      "spacing": 6
    },
    "custom/nyxus-panel": {
      "format": "",
      "tooltip": true,
      "on-click": "/home/nyx/.local/bin/nyxus-panel",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#a78bfa'>NYXUS · Panel</span>\n<span size='small' foreground='#b8a8d0'>Weather · News · System · Settings</span>"
    },
    "custom/nyxus-start": {
      "format": "",
      "escape": false,
      "tooltip": true,
      "on-click": "/home/nyx/.local/bin/nyxus-start",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#ff00ff'>NYXUS · Start</span>\n<span size='small' foreground='#b8a8d0'>Search · Pinned · Recent · Power</span>"
    }
  },
  {
    "name": "left",
    "layer": "top",
    "position": "left",
    "width": 52,
    "spacing": 0,
    "margin-top": 160,
    "margin-bottom": 160,
    "modules-center": [
      "hyprland/workspaces#left"
    ],
    "hyprland/workspaces#left": {
      "format": "{id}",
      "on-click": "activate",
      "sort-by-number": true
    }
  },
  {
    "name": "right",
    "layer": "top",
    "position": "right",
    "width": 52,
    "spacing": 0,
    "margin-top": 100,
    "margin-bottom": 100,
    "modules-left": [],
    "modules-center": [
      "custom/app-godsapp",
      "custom/app-studio",
      "custom/app-sage",
      "custom/app-shield",
      "custom/app-control",
      "custom/app-sysmon",
      "custom/app-stickies",
      "custom/app-weather",
      "custom/app-notepad",
      "custom/app-terminal",
      "custom/app-settings"
    ],
    "custom/app-godsapp": {
      "format": "",
      "tooltip": true,
      "on-click": "nyxus-godsapp",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#ffd700'>NYXUS GodsApp</span>\n<span size='small' foreground='#b8a8d0'>Configuration Hub</span>"
    },
    "custom/app-studio": {
      "format": "",
      "tooltip": true,
      "on-click": "nyxus-studio",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#ff3ea5'>NYXUS Studio</span>\n<span size='small' foreground='#b8a8d0'>Creative Suite</span>"
    },
    "custom/app-sage": {
      "format": "",
      "tooltip": true,
      "on-click": "nyxus-sage",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#4de2e2'>NYXUS SAGE</span>\n<span size='small' foreground='#b8a8d0'>Local AI Assistant</span>"
    },
    "custom/app-shield": {
      "format": "",
      "tooltip": true,
      "on-click": "nyxus-shield",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#4ade80'>NYXUS Shield</span>\n<span size='small' foreground='#b8a8d0'>Security Center</span>"
    },
    "custom/app-control": {
      "format": "",
      "tooltip": true,
      "on-click": "python3 /home/nyx/.nyxus/nyxus_control.py",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#ff3232'>NYXUS Control</span>\n<span size='small' foreground='#b8a8d0'>Hardware Control Center</span>"
    },
    "custom/app-sysmon": {
      "format": "",
      "tooltip": true,
      "on-click": "python3 /home/nyx/.nyxus/nyxus_sysmon_gtk.py",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#ff00ff'>NYXUS SysMon</span>\n<span size='small' foreground='#b8a8d0'>System Monitor</span>"
    },
    "custom/app-stickies": {
      "format": "",
      "tooltip": true,
      "on-click": "python3 /home/nyx/.nyxus/nyxus_stickies.py",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#ffff00'>NYXUS Stickies</span>\n<span size='small' foreground='#b8a8d0'>Sticky Notes</span>"
    },
    "custom/app-weather": {
      "format": "",
      "tooltip": true,
      "on-click": "python3 /home/nyx/.nyxus/nyxus_weather.py",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#0088ff'>NYXUS Weather</span>\n<span size='small' foreground='#b8a8d0'>Weather Forecast</span>"
    },
    "custom/app-notepad": {
      "format": "",
      "tooltip": true,
      "on-click": "python3 /home/nyx/.nyxus/nyxus_notepad.py",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#cc00ff'>NYXUS Notepad</span>\n<span size='small' foreground='#b8a8d0'>Quick Notes</span>"
    },
    "custom/app-terminal": {
      "format": "",
      "tooltip": true,
      "on-click": "python3 /home/nyx/.nyxus/nyxus_terminal.py",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#39ff14'>NYXUS Terminal</span>\n<span size='small' foreground='#b8a8d0'>Command Line</span>"
    },
    "custom/app-settings": {
      "format": "",
      "tooltip": true,
      "on-click": "python3 /home/nyx/.nyxus/nyxus_settings.py",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#a78bfa'>NYXUS Settings</span>\n<span size='small' foreground='#b8a8d0'>System Settings</span>"
    },
    "cpu#right": {
      "format": "{usage}",
      "interval": 2,
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#cc00ff'>NYXUS · CPU</span>\n<span size='small' foreground='#b8a8d0'>{usage}% utilization</span>"
    },
    "memory#right": {
      "format": "{percentage}",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#8800ff'>NYXUS · RAM</span>\n<span size='small' foreground='#b8a8d0'>{percentage}% used</span>"
    },
    "battery#right": {
      "format": "{capacity}",
      "format-charging": "{capacity}+",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#ffd700'>NYXUS · Battery</span>\n<span size='small' foreground='#b8a8d0'>{capacity}%</span>"
    },
    "modules-right": []
  }
]
