[
  {
    "name": "top",
    "layer": "top",
    "position": "top",
    "height": 78,
    "spacing": 0,
    "margin-top": 0,
    "margin-left": 0,
    "margin-right": 0,
    "modules-left": [
      "custom/ticker"
    ],
    "modules-center": [
      "custom/nyxus"
    ],
    "modules-right": [
      "clock#date",
      "clock",
      "clock#year",
      "custom/hyprland-side-top"
    ],
    "custom/ticker": {
      "exec": "~/.config/waybar/ticker.sh",
      "interval": 1,
      "format": "{}",
      "tooltip": false,
      "escape": false
    },
    "custom/nyxus": {
      "format": "<span size='xx-large' weight='bold' font_family='Architects Daughter'>NYXUS</span>\n<span size='small' letter_spacing='3000'>HYPRLAND</span>",
      "tooltip": true,
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#1a1816'>NYXUS \u00b7 Sierengowski</span>\n<span size='small' foreground='#58524c'>Hyprland \u00b7 Arch Linux \u00b7 2026</span>",
      "escape": false,
      "on-click": "/home/nyx/.local/bin/nyxus-start"
    },
    "clock#date": {
      "interval": 60,
      "format": "<span size='large' weight='bold'>{:%d}</span>\n<span size='x-small' weight='bold' letter_spacing='1500'>{:%b}</span>\n<span size='x-small' letter_spacing='1500'>{:%Y}</span>",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#1a1816'>NYXUS \u00b7 DATE</span>\n<span size='small' foreground='#58524c'>{:%A \u00b7 %B %d, %Y}</span>"
    },
    "clock": {
      "interval": 1,
      "format": "<span size='small'>\uf017</span>\n<span size='medium' weight='bold'>{:%H:%M:%S}</span>",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#1a1816'>NYXUS \u00b7 TIME</span>\n<span size='small' foreground='#58524c'>{:%H:%M:%S} \u00b7 {:%Z}</span>",
      "on-click": "sh -c 'pgrep -f nyxus_quicksettings >/dev/null && pkill -f nyxus_quicksettings || setsid python3 ~/.nyxus/nyxus_quicksettings.py >/tmp/nyxus-qs.log 2>&1 < /dev/null &'"
    },
    "clock#year": {
      "interval": 3600,
      "format": "<span size='x-small' weight='bold' letter_spacing='1500'>YEAR</span>\n<span size='large' weight='bold'>{:%Y}</span>\n<span size='x-small' letter_spacing='1500'>({:%Z})</span>",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#1a1816'>NYXUS \u00b7 YEAR</span>\n<span size='small' foreground='#58524c'>{:%Y \u00b7 %Z}</span>"
    },
    "custom/hyprland-side-top": {
      "format": "H\nY\nP\nR\nL\nA\nN\nD",
      "tooltip": true,
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#1a1816'>HYPRLAND \u00b7 WAYBAR</span>\n<span size='small' foreground='#58524c'>NYXUS Edition \u00b7 2026</span>"
    }
  },
  {
    "name": "bottom",
    "layer": "top",
    "position": "bottom",
    "height": 78,
    "spacing": 0,
    "margin-bottom": 0,
    "margin-left": 0,
    "margin-right": 0,
    "modules-left": [
      "custom/nyxus-start"
    ],
    "modules-center": [
      "hyprland/workspaces"
    ],
    "modules-right": [
      "cpu",
      "network#bottom",
      "pulseaudio",
      "battery#bottom",
      "custom/notifications",
      "custom/app-settings",
      "custom/nyxus-panel",
      "custom/nyxus-wordmark",
      "custom/hyprland-side"
    ],
    "custom/notifications": {
      "format": "\uf0f3\nAlerts",
      "tooltip": true,
      "on-click": "nyxus-notifications",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#1a1816'>NYXUS \u00b7 Notifications</span>\n<span size='small' foreground='#58524c'>Click to open the notification center</span>"
    },
    "custom/app-settings": {
      "format": "\uf085\nApps",
      "tooltip": true,
      "on-click": "sh -c 'if hyprctl clients -j | grep -q \"io.nyxus.settings\"; then hyprctl dispatch focuswindow class:io.nyxus.settings; else setsid python3 /home/nyx/.nyxus/nyxus_settings.py >/tmp/nyxus-settings.log 2>&1 < /dev/null & fi'",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#1a1816'>NYXUS \u00b7 Apps</span>\n<span size='small' foreground='#58524c'>System Settings &amp; Apps</span>"
    },
    "custom/nyxus-wordmark": {
      "format": "NYXUS",
      "tooltip": true,
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#1a1816'>NYXUS \u00b7 Sierengowski</span>\n<span size='small' foreground='#58524c'>Hyprland \u00b7 Arch Linux \u00b7 2026</span>",
      "on-click": "/home/nyx/.local/bin/nyxus-start"
    },
    "custom/hyprland-side": {
      "format": "H\nY\nP\nR\nL\nA\nN\nD",
      "tooltip": true,
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#1a1816'>HYPRLAND \u00b7 WAYBAR</span>\n<span size='small' foreground='#58524c'>Wayland Compositor \u00b7 NYXUS Edition</span>"
    },
    "hyprland/workspaces": {
      "format": "{id}\nWS {id}",
      "on-click": "activate",
      "sort-by-number": true,
      "active-only": false,
      "persistent-workspaces": {
        "*": 6
      }
    },
    "hyprland/window": {
      "format": "{}",
      "max-length": 52,
      "separate-outputs": true
    },
    "clock#bottom": {
      "interval": 1,
      "format": "  {:%a \u00b7 %d %b %Y \u00b7 %H:%M:%S}",
      "format-alt": "  {:%H:%M:%S}",
      "tooltip-format": "<span font='JetBrains Mono 13' foreground='#ff00ff'><b> {:%A}</b></span>\n<span font='JetBrains Mono 11' foreground='#ffffff'> {:%d %B %Y}</span>\n\n<span font='JetBrains Mono 10'><tt>{calendar}</tt></span>",
      "calendar": {
        "mode": "month",
        "on-scroll": 1,
        "format": {
          "months": "<span foreground='#ff00ff' font_weight='bold'>{}</span>",
          "days": "<span foreground='#ffffff'>{}</span>",
          "weeks": "<span foreground='#0088ff'><b>W{}</b></span>",
          "weekdays": "<span foreground='#ffff00' font_weight='bold'>{}</span>",
          "today": "<span foreground='#39ff14' font_weight='bold'><u>{}</u></span>"
        }
      }
    },
    "bluetooth": {
      "format": "  ",
      "format-disabled": "",
      "format-connected": "  {num_connections}",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#0088ff'>NYXUS \u00b7 Bluetooth</span>\n<span size='small' foreground='#b8a8d0'>{controller_alias}\n{device_enumerate}</span>",
      "on-click": "blueman-manager"
    },
    "cpu": {
      "format": "\uf2db\nCPU / Mem",
      "interval": 2,
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#1a1816'>NYXUS \u00b7 CPU / Memory</span>\n<span size='small' foreground='#58524c'>{usage}% utilization</span>"
    },
    "network#bottom": {
      "format-wifi": "\uf1eb\nNet",
      "format-ethernet": "\uf6ff\nNet",
      "format-disconnected": "\uf127\nNet",
      "interval": 2,
      "tooltip-format-wifi": "<span size='x-large' weight='bold' foreground='#1a1816'>NYXUS \u00b7 Wi-Fi</span>\n<span size='small' foreground='#58524c'>{essid}  \u00b7  {signalStrength}%\n{ipaddr}</span>",
      "on-click": "nm-connection-editor",
      "tooltip-format-ethernet": "<span size='x-large' weight='bold' foreground='#1a1816'>NYXUS \u00b7 Ethernet</span>\n<span size='small' foreground='#58524c'>{ifname}  \u00b7  {ipaddr}</span>",
      "tooltip-format-disconnected": "<span size='x-large' weight='bold' foreground='#1a1816'>NYXUS \u00b7 Network</span>\n<span size='small' foreground='#58524c'>No connection</span>"
    },
    "pulseaudio": {
      "format": "\uf028\nVol",
      "format-muted": "\uf026\nVol",
      "scroll-step": 5,
      "on-click": "pavucontrol",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#1a1816'>NYXUS \u00b7 Audio</span>\n<span size='small' foreground='#58524c'>{volume}%  \u00b7  {desc}</span>"
    },
    "battery#bottom": {
      "format": "{icon}\nBat",
      "format-charging": "\uf0e7\nBat",
      "format-plugged": "\uf1e6\nBat",
      "format-icons": [
        "",
        "",
        "",
        "",
        ""
      ],
      "states": {
        "warning": 30,
        "critical": 15
      },
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#1a1816'>NYXUS \u00b7 Battery</span>\n<span size='small' foreground='#58524c'>{capacity}% \u00b7 {time}</span>"
    },
    "tray": {
      "icon-size": 14,
      "spacing": 6
    },
    "custom/nyxus-panel": {
      "exec": "/home/nyx/.local/bin/nyxus-waybar-state panel",
      "interval": 1,
      "return-type": "json",
      "tooltip": true,
      "on-click": "/home/nyx/.local/bin/nyxus-panel",
      "format": "{}",
      "escape": false
    },
    "custom/nyxus-start": {
      "exec": "/home/nyx/.local/bin/nyxus-waybar-state start",
      "interval": 1,
      "return-type": "json",
      "tooltip": true,
      "on-click": "/home/nyx/.local/bin/nyxus-start",
      "format": "{}",
      "escape": false
    }
  },
  {
    "name": "left",
    "layer": "top",
    "position": "left",
    "width": 52,
    "spacing": 0,
    "margin-top": 160,
    "margin-bottom": 160,
    "modules-center": [
      "hyprland/workspaces#left"
    ],
    "hyprland/workspaces#left": {
      "format": "{id}",
      "on-click": "activate",
      "sort-by-number": true
    }
  },
  {
    "name": "right",
    "layer": "top",
    "position": "right",
    "width": 52,
    "spacing": 0,
    "margin-top": 100,
    "margin-bottom": 100,
    "modules-left": [],
    "modules-center": [
      "custom/app-godsapp",
      "custom/app-studio",
      "custom/app-sage",
      "custom/app-shield",
      "custom/app-control",
      "custom/app-sysmon",
      "custom/app-stickies",
      "custom/app-weather",
      "custom/app-notes",
      "custom/app-terminal",
      "custom/app-settings"
    ],
    "custom/app-godsapp": {
      "format": "\uf0d0",
      "tooltip": true,
      "on-click": "nyxus-godsapp",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#ffd700'>NYXUS GodsApp</span>\n<span size='small' foreground='#b8a8d0'>Configuration Hub</span>"
    },
    "custom/app-studio": {
      "format": "\uf1fc",
      "tooltip": true,
      "on-click": "nyxus-studio",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#ff3ea5'>NYXUS Studio</span>\n<span size='small' foreground='#b8a8d0'>Creative Suite</span>"
    },
    "custom/app-sage": {
      "format": "\uf19d",
      "tooltip": true,
      "on-click": "nyxus-sage",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#4de2e2'>NYXUS SAGE</span>\n<span size='small' foreground='#b8a8d0'>Local AI Assistant</span>"
    },
    "custom/app-shield": {
      "format": "\uf132",
      "tooltip": true,
      "on-click": "nyxus-shield",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#4ade80'>NYXUS Shield</span>\n<span size='small' foreground='#b8a8d0'>Security Center</span>"
    },
    "custom/app-control": {
      "format": "\uf2db",
      "tooltip": true,
      "on-click": "sh -c 'if hyprctl clients -j | grep -q \"io.nyxus.control\"; then hyprctl dispatch focuswindow class:io.nyxus.control; else setsid python3 /home/nyx/.nyxus/nyxus_control.py >/tmp/nyxus-control.log 2>&1 < /dev/null & fi'",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#ff3232'>NYXUS Control</span>\n<span size='small' foreground='#b8a8d0'>Hardware Control Center</span>"
    },
    "custom/app-sysmon": {
      "format": "\uf201",
      "tooltip": true,
      "on-click": "sh -c 'if hyprctl clients -j | grep -q \"io.nyxus.sysmon\"; then hyprctl dispatch focuswindow class:io.nyxus.sysmon; else setsid python3 /home/nyx/.nyxus/nyxus_sysmon_gtk.py >/tmp/nyxus-sysmon.log 2>&1 < /dev/null & fi'",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#ff00ff'>NYXUS SysMon</span>\n<span size='small' foreground='#b8a8d0'>System Monitor</span>"
    },
    "custom/app-stickies": {
      "format": "\uf249",
      "tooltip": true,
      "on-click": "sh -c 'if hyprctl clients -j | grep -q \"io.nyxus.stickies\"; then hyprctl dispatch focuswindow class:io.nyxus.stickies; else setsid python3 /home/nyx/.nyxus/nyxus_stickies.py >/tmp/nyxus-stickies.log 2>&1 < /dev/null & fi'",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#ffff00'>NYXUS Stickies</span>\n<span size='small' foreground='#b8a8d0'>Sticky Notes</span>"
    },
    "custom/app-weather": {
      "format": "\uf0c2",
      "tooltip": true,
      "on-click": "python3 /home/nyx/.nyxus/nyxus_weather.py",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#0088ff'>NYXUS Weather</span>\n<span size='small' foreground='#b8a8d0'>Weather Forecast</span>"
    },
    "custom/app-notes": {
      "format": "\uf249",
      "tooltip": true,
      "on-click": "sh -c 'if hyprctl clients -j | grep -q \"org.nyxus.notes\"; then hyprctl dispatch focuswindow class:org.nyxus.notes; else setsid /usr/local/bin/nyxus-notes >/tmp/nyxus-notes.log 2>&1 < /dev/null & fi'",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#58524c'>NYXUS Notes</span>\n<span size='small' foreground='#9e948a'>Plain text · auto-saved</span>"
    },
    "custom/app-terminal": {
      "format": "\uf120",
      "tooltip": true,
      "on-click": "sh -c 'if hyprctl clients -j | grep -q \"io.nyxus.terminal\"; then hyprctl dispatch focuswindow class:io.nyxus.terminal; else setsid python3 /home/nyx/.nyxus/nyxus_terminal.py >/tmp/nyxus-terminal.log 2>&1 < /dev/null & fi'",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#39ff14'>NYXUS Terminal</span>\n<span size='small' foreground='#b8a8d0'>Command Line</span>"
    },
    "custom/app-settings": {
      "format": "\uf085",
      "tooltip": true,
      "on-click": "sh -c 'if hyprctl clients -j | grep -q \"io.nyxus.settings\"; then hyprctl dispatch focuswindow class:io.nyxus.settings; else setsid python3 /home/nyx/.nyxus/nyxus_settings.py >/tmp/nyxus-settings.log 2>&1 < /dev/null & fi'",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#a78bfa'>NYXUS Settings</span>\n<span size='small' foreground='#b8a8d0'>System Settings</span>"
    },
    "cpu#right": {
      "format": "{usage}",
      "interval": 2,
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#cc00ff'>NYXUS \u00b7 CPU</span>\n<span size='small' foreground='#b8a8d0'>{usage}% utilization</span>"
    },
    "memory#right": {
      "format": "{percentage}",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#8800ff'>NYXUS \u00b7 RAM</span>\n<span size='small' foreground='#b8a8d0'>{percentage}% used</span>"
    },
    "battery#right": {
      "format": "{capacity}",
      "format-charging": "{capacity}+",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#ffd700'>NYXUS \u00b7 Battery</span>\n<span size='small' foreground='#b8a8d0'>{capacity}%</span>"
    },
    "modules-right": []
  }
]