[
  {
    "name": "top",
    "layer": "top",
    "position": "top",
    "height": 45,
    "spacing": 4,
    "margin-top": 10,
    "margin-left": 20,
    "margin-right": 20,
    "modules-left": ["custom/ticker"],
    "modules-center": ["custom/nyxus"],
    "modules-right": ["clock", "custom/weather"],

    "custom/ticker": {
      "exec": "~/.config/waybar/waybar-ticker.sh",
      "interval": 1,
      "return-type": "json",
      "tooltip": false,
      "escape": false
    },
    "custom/nyxus": {
      "format": " NYXUS ",
      "tooltip": true,
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#1a1816'>NYXUS · Sierengowski</span>\n<span size='small' foreground='#58524c'>Hyprland · Arch Linux · 2026</span>",
      "on-click": "/home/nyx/.local/bin/nyxus-start"
    },
    "clock": {
      "interval": 1,
      "format": "{0:%H:%M} | {0:%a %d}",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#1a1816'>NYXUS · {0:%A}</span>\n<span size='small' foreground='#58524c'>{0:%B %d, %Y · %H:%M:%S %Z}</span>",
      "on-click": "sh -c 'pgrep -f nyxus_quicksettings >/dev/null && pkill -f nyxus_quicksettings || setsid python3 ~/.nyxus/nyxus_quicksettings.py >/tmp/nyxus-qs.log 2>&1 < /dev/null &'"
    },
    "custom/weather": {
      "exec": "curl -fsS --max-time 4 'wttr.in/?format=1' 2>/dev/null || echo '— —'",
      "interval": 3600,
      "tooltip": true,
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#1a1816'>NYXUS · Weather</span>\n<span size='small' foreground='#58524c'>via wttr.in · refreshes hourly</span>",
      "on-click": "python3 /home/nyx/.nyxus/nyxus_weather.py"
    }
  },
  {
    "name": "left",
    "layer": "top",
    "position": "left",
    "width": 50,
    "spacing": 0,
    "margin-top": 60,
    "margin-bottom": 60,
    "margin-left": 10,
    "modules-center": ["cpu", "memory", "disk"],

    "cpu": {
      "interval": 2,
      "format": "{usage}%",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#1a1816'>NYXUS · CPU</span>\n<span size='small' foreground='#58524c'>{usage}% utilization</span>",
      "on-click": "sh -c 'if hyprctl clients -j | grep -q \"io.nyxus.sysmon\"; then hyprctl dispatch focuswindow class:io.nyxus.sysmon; else setsid python3 /home/nyx/.nyxus/nyxus_sysmon_gtk.py >/tmp/nyxus-sysmon.log 2>&1 < /dev/null & fi'"
    },
    "memory": {
      "interval": 5,
      "format": "{percentage}%",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#1a1816'>NYXUS · RAM</span>\n<span size='small' foreground='#58524c'>{used:0.1f}G / {total:0.1f}G</span>",
      "on-click": "sh -c 'if hyprctl clients -j | grep -q \"io.nyxus.sysmon\"; then hyprctl dispatch focuswindow class:io.nyxus.sysmon; else setsid python3 /home/nyx/.nyxus/nyxus_sysmon_gtk.py >/tmp/nyxus-sysmon.log 2>&1 < /dev/null & fi'"
    },
    "disk": {
      "interval": 30,
      "format": "{percentage_used}%",
      "path": "/",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#1a1816'>NYXUS · Disk</span>\n<span size='small' foreground='#58524c'>{used} / {total} used</span>"
    }
  },
  {
    "name": "right",
    "layer": "top",
    "position": "right",
    "width": 50,
    "spacing": 0,
    "margin-top": 60,
    "margin-bottom": 60,
    "margin-right": 10,
    "modules-center": ["network", "pulseaudio", "battery"],

    "network": {
      "format-wifi": "",
      "format-ethernet": "",
      "format-disconnected": "",
      "interval": 5,
      "on-click": "nm-connection-editor",
      "tooltip-format-wifi": "<span size='x-large' weight='bold' foreground='#1a1816'>NYXUS · Wi-Fi</span>\n<span size='small' foreground='#58524c'>{essid} · {signalStrength}%\n{ipaddr}</span>",
      "tooltip-format-ethernet": "<span size='x-large' weight='bold' foreground='#1a1816'>NYXUS · Ethernet</span>\n<span size='small' foreground='#58524c'>{ifname} · {ipaddr}</span>",
      "tooltip-format-disconnected": "<span size='x-large' weight='bold' foreground='#1a1816'>NYXUS · Network</span>\n<span size='small' foreground='#58524c'>Disconnected</span>"
    },
    "pulseaudio": {
      "format": "{icon}",
      "format-muted": "",
      "format-icons": ["", "", ""],
      "scroll-step": 5,
      "on-click": "pavucontrol",
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#1a1816'>NYXUS · Audio</span>\n<span size='small' foreground='#58524c'>{volume}% · {desc}</span>"
    },
    "battery": {
      "interval": 30,
      "format": "{icon}",
      "format-charging": "",
      "format-plugged": "",
      "format-icons": ["", "", "", "", ""],
      "states": { "warning": 30, "critical": 15 },
      "tooltip-format": "<span size='x-large' weight='bold' foreground='#1a1816'>NYXUS · Battery</span>\n<span size='small' foreground='#58524c'>{capacity}% · {time}</span>"
    }
  }
]
