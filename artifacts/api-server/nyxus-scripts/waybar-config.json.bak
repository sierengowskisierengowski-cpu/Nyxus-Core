[
  {
    "name": "top",
    "layer": "top",
    "position": "top",
    "height": 28,
    "spacing": 0,
    "margin-top": 0,
    "margin-left": 0,
    "margin-right": 0,
    "modules-left": [
      "custom/ticker"
    ],
    "modules-center": [
      "custom/nyxus"
    ],
    "modules-right": [],
    "custom/ticker": {
      "exec": "~/.config/waybar/ticker.sh",
      "interval": 1,
      "format": "{}",
      "tooltip": false
    },
    "custom/nyxus": {
      "format": "<span foreground='#ff00ff' font_weight='bold'>N</span><span foreground='#ff5500' font_weight='bold'> Y</span><span foreground='#ffff00' font_weight='bold'> X</span><span foreground='#39ff14' font_weight='bold'> U</span><span foreground='#0088ff' font_weight='bold'> S</span>",
      "tooltip": false,
      "escape": false
    },
    "custom/sep": {
      "format": "◈",
      "tooltip": false
    },
    "cpu": {
      "format": "  {usage}%",
      "interval": 2,
      "tooltip": false
    },
    "memory": {
      "format": "  {percentage}%",
      "tooltip": false
    },
    "temperature": {
      "hwmon-path-abs": "/sys/class/thermal/thermal_zone0/temp",
      "input-filename": "temp",
      "critical-threshold": 80,
      "format": "  {temperatureC}°C",
      "format-critical": "  {temperatureC}°C",
      "tooltip": false
    },
    "network": {
      "format-wifi": "  {essid}  ↓{bandwidthDownBytes}  ↑{bandwidthUpBytes}",
      "format-ethernet": "  ETH  ↓{bandwidthDownBytes}  ↑{bandwidthUpBytes}",
      "format-disconnected": "  NO NET",
      "interval": 2,
      "tooltip-format": "{ipaddr}  ·  {ifname}"
    },
    "battery": {
      "format": "{icon}  {capacity}%",
      "format-charging": "  {capacity}%",
      "format-plugged": "  {capacity}%",
      "format-icons": [
        "",
        "",
        "",
        "",
        ""
      ],
      "states": {
        "warning": 30,
        "critical": 15
      },
      "tooltip": false
    },
    "clock": {
      "interval": 1,
      "format": "  {:%H:%M:%S}",
      "format-alt": "  {:%a %b %d  ·  %H:%M:%S}",
      "tooltip-format": "<big>{:%A  %B %d  %Y}</big>"
    }
  },
  {
    "name": "bottom",
    "layer": "top",
    "position": "bottom",
    "height": 60,
    "spacing": 0,
    "margin-bottom": 0,
    "margin-left": 0,
    "margin-right": 0,
    "modules-left": [
      "custom/start"
    ],
    "modules-center": [
      "hyprland/workspaces"
    ],
    "modules-right": [
      "custom/quicksettings",
      "clock#bottom"
    ],
    "custom/start": {
      "format": "✕",
      "escape": false,
      "tooltip": false,
      "on-click": "rofi -show drun -theme ~/.config/rofi/startmenu.rasi"
    },
    "custom/quicksettings": {
      "format": "",
      "tooltip": false,
      "on-click": "python3 ~/.config/waybar/quicksettings.py"
    },
    "hyprland/workspaces": {
      "format": "{id}",
      "on-click": "activate",
      "sort-by-number": true,
      "active-only": false,
      "persistent-workspaces": {
        "*": 6
      }
    },
    "hyprland/window": {
      "format": "{}",
      "max-length": 52,
      "separate-outputs": true
    },
    "clock#bottom": {
      "interval": 1,
      "format": "  {:%a · %d %b %Y · %H:%M:%S}",
      "format-alt": "  {:%H:%M:%S}",
      "tooltip-format": "<span font='JetBrains Mono 13' foreground='#ff00ff'><b> {:%A}</b></span>\n<span font='JetBrains Mono 11' foreground='#ffffff'> {:%d %B %Y}</span>\n\n<span font='JetBrains Mono 10'><tt>{calendar}</tt></span>",
      "calendar": {
        "mode": "month",
        "on-scroll": 1,
        "format": {
          "months": "<span foreground='#ff00ff' font_weight='bold'>{}</span>",
          "days": "<span foreground='#ffffff'>{}</span>",
          "weeks": "<span foreground='#0088ff'><b>W{}</b></span>",
          "weekdays": "<span foreground='#ffff00' font_weight='bold'>{}</span>",
          "today": "<span foreground='#39ff14' font_weight='bold'><u>{}</u></span>"
        }
      }
    },
    "bluetooth": {
      "format": "  ",
      "format-disabled": "",
      "format-connected": "  {num_connections}",
      "tooltip-format": "{controller_alias}\n{device_enumerate}",
      "on-click": "blueman-manager"
    },
    "network#bottom": {
      "format-wifi": "  {signalStrength}%",
      "format-ethernet": "  ETH",
      "format-disconnected": "  ",
      "tooltip-format-wifi": "{essid}  {signalStrength}%\n{ipaddr}",
      "on-click": "nm-connection-editor"
    },
    "pulseaudio": {
      "format": "  {volume}%",
      "format-muted": "  ",
      "scroll-step": 5,
      "on-click": "pavucontrol"
    },
    "battery#bottom": {
      "format": "{icon}  {capacity}%",
      "format-charging": "  {capacity}%",
      "format-plugged": "  {capacity}%",
      "format-icons": [
        "",
        "",
        "",
        "",
        ""
      ],
      "states": {
        "warning": 30,
        "critical": 15
      }
    },
    "tray": {
      "icon-size": 14,
      "spacing": 6
    }
  },
  {
    "name": "left",
    "layer": "top",
    "position": "left",
    "width": 52,
    "spacing": 0,
    "margin-top": 160,
    "margin-bottom": 160,
    "modules-center": [
      "hyprland/workspaces#left"
    ],
    "hyprland/workspaces#left": {
      "format": "{id}",
      "on-click": "activate",
      "sort-by-number": true
    }
  },
  {
    "name": "right",
    "layer": "top",
    "position": "right",
    "width": 52,
    "spacing": 0,
    "margin-top": 100,
    "margin-bottom": 100,
    "modules-left": [],
    "modules-center": [
      "custom/app-godsapp",
      "custom/app-studio",
      "custom/app-sage",
      "custom/app-shield",
      "custom/app-control",
      "custom/app-sysmon",
      "custom/app-stickies",
      "custom/app-weather",
      "custom/app-notepad",
      "custom/app-terminal",
      "custom/app-settings"
    ],
    "custom/app-godsapp": {
      "format": "",
      "tooltip": true,
      "on-click": "python3 -m godsapp.main",
      "tooltip-format": "<span size=\"x-large\" weight=\"bold\" foreground=\"#ffd700\">NYXUS</span>\n<span size=\"large\" weight=\"bold\" foreground=\"#ffffff\">GodsApp</span>\n<span size=\"small\" foreground=\"#b8a8d0\">Configuration Hub</span>"
    },
    "custom/app-studio": {
      "format": "",
      "tooltip": true,
      "on-click": "python3 -m studio.main",
      "tooltip-format": "<span size=\"x-large\" weight=\"bold\" foreground=\"#ff3ea5\">NYXUS</span>\n<span size=\"large\" weight=\"bold\" foreground=\"#ffffff\">Studio</span>\n<span size=\"small\" foreground=\"#b8a8d0\">Creative Suite</span>"
    },
    "custom/app-sage": {
      "format": "",
      "tooltip": true,
      "on-click": "python3 -m sage.main",
      "tooltip-format": "<span size=\"x-large\" weight=\"bold\" foreground=\"#4de2e2\">NYXUS</span>\n<span size=\"large\" weight=\"bold\" foreground=\"#ffffff\">SAGE</span>\n<span size=\"small\" foreground=\"#b8a8d0\">Local AI Assistant</span>"
    },
    "custom/app-shield": {
      "format": "",
      "tooltip": true,
      "on-click": "python3 -m shield.main",
      "tooltip-format": "<span size=\"x-large\" weight=\"bold\" foreground=\"#4ade80\">NYXUS</span>\n<span size=\"large\" weight=\"bold\" foreground=\"#ffffff\">Shield</span>\n<span size=\"small\" foreground=\"#b8a8d0\">Security Center</span>"
    },
    "custom/app-control": {
      "format": "",
      "tooltip": true,
      "on-click": "python3 /home/nyx/.nyxus/nyxus_control.py",
      "tooltip-format": "<span size=\"x-large\" weight=\"bold\" foreground=\"#ff3232\">NYXUS</span>\n<span size=\"large\" weight=\"bold\" foreground=\"#ffffff\">Control</span>\n<span size=\"small\" foreground=\"#b8a8d0\">Hardware Control Center</span>"
    },
    "custom/app-sysmon": {
      "format": "",
      "tooltip": true,
      "on-click": "python3 /home/nyx/.nyxus/nyxus_sysmon_gtk.py",
      "tooltip-format": "<span size=\"x-large\" weight=\"bold\" foreground=\"#ff00ff\">NYXUS</span>\n<span size=\"large\" weight=\"bold\" foreground=\"#ffffff\">SysMon</span>\n<span size=\"small\" foreground=\"#b8a8d0\">System Monitor</span>"
    },
    "custom/app-stickies": {
      "format": "",
      "tooltip": true,
      "on-click": "python3 /home/nyx/.nyxus/nyxus_stickies.py",
      "tooltip-format": "<span size=\"x-large\" weight=\"bold\" foreground=\"#ffff00\">NYXUS</span>\n<span size=\"large\" weight=\"bold\" foreground=\"#ffffff\">Stickies</span>\n<span size=\"small\" foreground=\"#b8a8d0\">Sticky Notes</span>"
    },
    "custom/app-weather": {
      "format": "",
      "tooltip": true,
      "on-click": "python3 /home/nyx/.nyxus/nyxus_weather.py",
      "tooltip-format": "<span size=\"x-large\" weight=\"bold\" foreground=\"#0088ff\">NYXUS</span>\n<span size=\"large\" weight=\"bold\" foreground=\"#ffffff\">Weather</span>\n<span size=\"small\" foreground=\"#b8a8d0\">Weather Forecast</span>"
    },
    "custom/app-notepad": {
      "format": "",
      "tooltip": true,
      "on-click": "python3 /home/nyx/.nyxus/nyxus_notepad.py",
      "tooltip-format": "<span size=\"x-large\" weight=\"bold\" foreground=\"#cc00ff\">NYXUS</span>\n<span size=\"large\" weight=\"bold\" foreground=\"#ffffff\">Notepad</span>\n<span size=\"small\" foreground=\"#b8a8d0\">Quick Notes</span>"
    },
    "custom/app-terminal": {
      "format": "",
      "tooltip": true,
      "on-click": "python3 /home/nyx/.nyxus/nyxus_terminal.py",
      "tooltip-format": "<span size=\"x-large\" weight=\"bold\" foreground=\"#39ff14\">NYXUS</span>\n<span size=\"large\" weight=\"bold\" foreground=\"#ffffff\">Terminal</span>\n<span size=\"small\" foreground=\"#b8a8d0\">Command Line</span>"
    },
    "custom/app-settings": {
      "format": "",
      "tooltip": true,
      "on-click": "python3 /home/nyx/.nyxus/nyxus_settings.py",
      "tooltip-format": "<span size=\"x-large\" weight=\"bold\" foreground=\"#a78bfa\">NYXUS</span>\n<span size=\"large\" weight=\"bold\" foreground=\"#ffffff\">Settings</span>\n<span size=\"small\" foreground=\"#b8a8d0\">System Settings</span>"
    },
    "cpu#right": {
      "format": "{usage}",
      "interval": 2,
      "tooltip": false
    },
    "memory#right": {
      "format": "{percentage}",
      "tooltip": false
    },
    "battery#right": {
      "format": "{capacity}",
      "format-charging": "{capacity}+",
      "tooltip": false
    },
    "modules-right": []
  }
]